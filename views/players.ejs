<!DOCTYPE html>
<html>
<head>
    <title>Room <%= roomCode %></title>
</head>
<body>

<h2>Room Code: <%= roomCode %></h2>

<h3>Players:</h3>
<ul id="playerList"></ul>

<br>

<button id="leaveBtn">Leave Room</button>

<br><br>
<h3 id="drawerText"></h3>

<canvas id="board" width="900" height="500"
style="border:1px solid black;"></canvas>

<br><br>

<button id="clearBtn">Clear</button>

<script src="/socket.io/socket.io.js"></script>

<script>
    const socket = io();

    const roomCode = "<%= roomCode %>";
    const username = "<%= username %>";

    const playerList = document.getElementById("playerList");
    const leaveBtn = document.getElementById("leaveBtn");
    const canvas = document.getElementById("board");
    const ctx = canvas.getContext("2d");
    const clearBtn = document.getElementById("clearBtn");

    let drawing = false;

    // Black brush setup
    ctx.strokeStyle = "black";
    ctx.lineWidth = 3;
    ctx.lineCap = "round";

    // Join room
    socket.emit("joinRoom", { roomCode, username });

    // Update player list
    socket.on("updatePlayers", (players) => {
        playerList.innerHTML = "";
        players.forEach(player => {
            const li = document.createElement("li");
            li.textContent = player;
            playerList.appendChild(li);
        });
    });

    // Leave button
    leaveBtn.addEventListener("click", () => {
        socket.disconnect();
        window.location.href = "/joingame";
    });

    // Drawing logic
    canvas.addEventListener("mousedown", (e) => {
        if (!isDrawer) return;

        drawing = true;

        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        ctx.beginPath();
        ctx.moveTo(x, y);

        socket.emit("draw", { x, y, type: "start" });
    });

    canvas.addEventListener("mouseup", () => {
        if (!isDrawer) return;

        drawing = false;
        ctx.beginPath();

        socket.emit("draw", { type: "end" });
    });

    canvas.addEventListener("mouseleave", () => {
        drawing = false;
        ctx.beginPath();
    });

    canvas.addEventListener("mousemove", (e) => {
        if (!drawing || !isDrawer) return;

        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        ctx.lineTo(x, y);
        ctx.stroke();

        socket.emit("draw", { x, y, type: "draw" });
    });

    function draw(x, y) {
        ctx.lineTo(x, y);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(x, y);
    }

    // Receive drawing from others
    socket.on("draw", (data) => {

        if (data.type === "start") {
            ctx.beginPath();
            ctx.moveTo(data.x, data.y);
        }

        if (data.type === "draw") {
            ctx.lineTo(data.x, data.y);
            ctx.stroke();
        }

        if (data.type === "end") {
            ctx.beginPath();
        }
    });

    // Clear button
    clearBtn.addEventListener("click", () => {
        if (!isDrawer) return;

        clearCanvas();
        socket.emit("clear");
    });

    function clearCanvas() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
    }

    socket.on("clear", () => {
        clearCanvas();
    });

    let isDrawer = false;

    socket.on("updateDrawer", (data) => {

        const drawerId = data.id;
        const drawerName = data.name;

        isDrawer = socket.id === drawerId;

        const drawerText = document.getElementById("drawerText");

        if (isDrawer) {
            drawerText.textContent = "You are drawing!";
        } else {
            drawerText.textContent = drawerName + " is drawing...";
        }
    });
    


</script>

</body>
</html>