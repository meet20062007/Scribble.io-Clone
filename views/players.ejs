<!DOCTYPE html>
<html>
<head>
    <title>Room <%= roomCode %></title>
    <link rel="stylesheet" href="/styles/game.css">
</head>
<body>

<div class="app">

    <div id="roundOverlay" class="overlay" style="display:none;">
        <div class="scoreCard">
            <h2 style="color: #000000;">Round Results</h2>
            <ul id="roundScores"></ul>
        </div>
    </div>

    <!-- TOP BAR -->
    <div class="top-bar">
        <div class="room-section">
            <h2>Room: <%= roomCode %></h2>
            <h3 id="drawerText"></h3>
        </div>
        <div class="timer-section">
            ⏱ <span id="timer">90</span>s
        </div>
    </div>

    <!-- MAIN AREA -->
    <div class="main-container">

        <!-- LEFT: PLAYERS -->
        <div class="players-panel">
            <h3>Players</h3>
            <ul id="playerList"></ul>
            <button id="leaveBtn">Leave Room</button>
        </div>

        <!-- CENTER: CANVAS -->
        <div class="canvas-panel">
            <canvas id="board" width="1200" height="650"></canvas>

            <div class="tool-row">
                <div id="colorPicker">
                    <button class="color-btn" data-color="black" style="background:black;"></button>
                    <button class="color-btn" data-color="red" style="background:red;"></button>
                    <button class="color-btn" data-color="blue" style="background:blue;"></button>
                    <button class="color-btn" data-color="green" style="background:green;"></button>
                    <button class="color-btn" data-color="yellow" style="background:yellow;"></button>
                </div>

                <button id="eraserBtn">🧽 Eraser</button>
                <button id="clearBtn">Clear</button>
            </div>

            <div id="wordSelection" style="display:none;">
                <h3>Choose a word:</h3>
                <div id="wordOptions"></div>
            </div>

            <h1 id="wordHint"></h1>
        </div>

        <!-- RIGHT: CHAT -->
        <div class="chat-panel">
            <h3>Guess</h3>
            <div id="chatMessages"></div>
            <div id =guessBox>
                <input type="text" id="chatInput" placeholder="Type your guess..." />
                <button id="sendBtn">Send</button>
            </div>
        </div>

    </div>

</div>

<script src="/socket.io/socket.io.js"></script>

<script>
    const socket = io();

    const roomCode = "<%= roomCode %>";
    const username = "<%= username %>";

    const playerList = document.getElementById("playerList");
    const leaveBtn = document.getElementById("leaveBtn");
    const canvas = document.getElementById("board");
    const toolRow = document.querySelector(".tool-row");
    const ctx = canvas.getContext("2d");
    let currentColor = "black";
    let currentSize = 3;
    ctx.strokeStyle = currentColor;
    ctx.lineWidth = currentSize;
    const colorButtons = document.querySelectorAll(".color-btn");

    colorButtons.forEach(button => {
        button.addEventListener("click", () => {

            currentColor = button.getAttribute("data-color");
            currentSize = 3; // reset to normal brush size

            ctx.strokeStyle = currentColor;
            ctx.lineWidth = currentSize;
        });
    });

    const eraserBtn = document.getElementById("eraserBtn");

    eraserBtn.addEventListener("click", () => {

        currentColor = "white";
        currentSize = 90;

        ctx.strokeStyle = currentColor;
        ctx.lineWidth = currentSize;
    });

    const clearBtn = document.getElementById("clearBtn");

    let drawing = false;

    // Black brush setup
    ctx.strokeStyle = "black";
    ctx.lineWidth = 3;
    ctx.lineCap = "round";

    // Join room
    socket.emit("joinRoom", { roomCode, username });

    // Update player list
    socket.on("updatePlayers", (players) => {

        playerList.innerHTML = "";

        players.forEach(player => {

            const li = document.createElement("li");
            li.textContent = player.username + " - " + player.score;
            li.id = "player-" + player.username;

            playerList.appendChild(li);
        });
    });

    // Leave button
    leaveBtn.addEventListener("click", () => {
        socket.disconnect();
        window.location.href = "/joingame";
    });

    // Drawing logic
    canvas.addEventListener("mousedown", (e) => {
        if (!isDrawer) return;

        drawing = true;

        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        ctx.beginPath();
        ctx.moveTo(x, y);

        socket.emit("draw", { 
            x, 
            y, 
            type: "start", 
            color: currentColor,
            size: currentSize
        });
    });

    canvas.addEventListener("mouseup", () => {
        if (!isDrawer) return;

        drawing = false;
        ctx.beginPath();

        socket.emit("draw", { type: "end" });
    });

    canvas.addEventListener("mouseleave", () => {
        drawing = false;
        ctx.beginPath();
    });

    canvas.addEventListener("mousemove", (e) => {
        if (!drawing || !isDrawer) return;

        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        ctx.lineTo(x, y);
        ctx.stroke();

        socket.emit("draw", { 
            x, 
            y, 
            type: "draw", 
            color: currentColor,
            size: currentSize
        });
    });

    // ===== MOBILE TOUCH SUPPORT =====

canvas.addEventListener("touchstart", (e) => {
    if (!isDrawer) return;

    e.preventDefault();

    drawing = true;

    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];

    const x = touch.clientX - rect.left;
    const y = touch.clientY - rect.top;

    ctx.beginPath();
    ctx.moveTo(x, y);

    socket.emit("draw", {
        x,
        y,
        type: "start",
        color: currentColor,
        size: currentSize
    });
});

canvas.addEventListener("touchmove", (e) => {
    if (!drawing || !isDrawer) return;

    e.preventDefault();

    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];

    const x = touch.clientX - rect.left;
    const y = touch.clientY - rect.top;

    ctx.lineTo(x, y);
    ctx.stroke();

    socket.emit("draw", {
        x,
        y,
        type: "draw",
        color: currentColor,
        size: currentSize
    });
});

canvas.addEventListener("touchend", () => {
    if (!isDrawer) return;

    drawing = false;
    ctx.beginPath();

    socket.emit("draw", { type: "end" });
});

    function draw(x, y) {
        ctx.lineTo(x, y);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(x, y);
    }

    // Receive drawing from others
    socket.on("draw", (data) => {
        ctx.strokeStyle = data.color || "black";
        ctx.lineWidth = data.size || 3;

        if (data.type === "start") {
            ctx.beginPath();
            ctx.moveTo(data.x, data.y);
        }

        if (data.type === "draw") {
            ctx.lineTo(data.x, data.y);
            ctx.stroke();
        }

        if (data.type === "end") {
            ctx.beginPath();
        }
    });

    // Clear button
    clearBtn.addEventListener("click", () => {
        if (!isDrawer) return;

        clearCanvas();
        socket.emit("clear");
    });

    function clearCanvas() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
    }

    socket.on("clear", () => {
        clearCanvas();
    });

    let isDrawer = false;

    socket.on("updateDrawer", ({drawerId,drawerName,state}) => {

        if (countdownInterval) 
        {
            clearInterval(countdownInterval);
            document.getElementById("timer").textContent = 90;
        }

        isDrawer = socket.id === drawerId;

        if (isDrawer) {
            guessBox.style.display = "none";
            toolRow.style.display = "flex";
        } else {
            guessBox.style.display = "block";
            toolRow.style.display = "none";
        }

        const drawerText = document.getElementById("drawerText");

        if (isDrawer) {
            if (state === "choosing a word") {
                drawerText.textContent = "Choose a word!";
            } else {
                drawerText.textContent = "You are drawing!";
            }
        } else {
            if (state === "choosing a word") {
                drawerText.textContent = drawerName + " is choosing a word...";
            } else {
                drawerText.textContent = drawerName + " is drawing...";
            }
        }
    });
    
    let countdownInterval;

    socket.on("roundStarted", ({ duration, startTime }) => {

        const timerElement = document.getElementById("timer");

        // Clear old interval if exists
        if (countdownInterval) {
            clearInterval(countdownInterval);
        }

        function updateTimer() {

            const elapsed = Math.floor((Date.now() - startTime) / 1000);
            const timeLeft = duration - elapsed;

            timerElement.textContent = timeLeft > 0 ? timeLeft : 0;

            if (timeLeft <= 0) {
                clearInterval(countdownInterval);
            }
        }

        updateTimer();
        countdownInterval = setInterval(updateTimer, 1000);//the setinterval is an inbuilt function which runs a specific function every given interval . In this case updateTimer every 1 second
    });

            const wordSelection = document.getElementById("wordSelection");
        const wordOptionsDiv = document.getElementById("wordOptions");
        const wordHint = document.getElementById("wordHint");
        let wordLength = 0;

        socket.on("chooseWord", (words) => {

            wordSelection.style.display = "block";
            wordOptionsDiv.innerHTML = "";

            words.forEach(word => {
                const btn = document.createElement("button");
                btn.textContent = word;

                btn.onclick = () => {
                    socket.emit("wordSelected", word);
                    wordSelection.style.display = "none";
                };

                wordOptionsDiv.appendChild(btn);
            });
        });

        socket.on("wordChosen", ({ length,word }) => {

            hasGuessedCorrectly = false;  // Reset when new word is chosen
            wordLength = length;  // Store the length

            if (isDrawer) {
                wordHint.textContent = "You chose: " + word;
            } else {
                wordHint.textContent = "_ ".repeat(length) + " (" + length + ")";
            }
        });

        socket.on("hintUpdate", ({ hint }) => {
            // Only guessers (non-drawers) who haven't guessed correctly should see hints
            if (!isDrawer && !hasGuessedCorrectly) {
                wordHint.textContent = hint + " (" + wordLength + ")";
            }
        });

        const chatInput = document.getElementById("chatInput");
        const sendBtn = document.getElementById("sendBtn");
        const guessBox = document.getElementById("guessBox");
        const chatMessages = document.getElementById("chatMessages");

        sendBtn.addEventListener("click", sendGuess);
        chatInput.addEventListener("keypress", (e) => {
            if (e.key === "Enter") sendGuess();
        });

        function sendGuess() {
            const guess = chatInput.value.trim();
            if (!guess) return;

            socket.emit("guess", guess);
            chatInput.value = "";
        }

        socket.on("correctGuess", ({ username }) => {
            const li = document.getElementById("player-" + username);
            if (li) {
                li.style.color = "green";
                li.style.fontWeight = "bold";
            }

            const msg = document.createElement("div");
            msg.textContent = username + " guessed correctly!";
            msg.style.fontStyle = "italic";
            chatMessages.appendChild(msg);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        });

        socket.on("revealWord",({correctWord})=>{
            hasGuessedCorrectly = true;  // Mark that user guessed correctly
            wordHint.textContent = correctWord;
        });
        socket.on("chatMessage", ({ username, message }) => {
            const msg = document.createElement("div");
            msg.textContent = username + ": " + message;

            chatMessages.appendChild(msg);

            chatMessages.scrollTop = chatMessages.scrollHeight;
        });

        function resetPlayerColors() {      // Reset all player colors to black when a new round starts which were changed to green on correct guess
            const listItems = document.querySelectorAll("#playerList li");

            listItems.forEach(li => {
                li.style.color = "black";
                li.style.fontWeight = "normal";
            });
        }

        socket.on("roundEnded", (roundResults) => {

            const overlay = document.getElementById("roundOverlay");
            const list = document.getElementById("roundScores");

            list.innerHTML = "";

            roundResults.forEach(player => {
                const li = document.createElement("li");
                li.textContent = player.username + " + " + player.points;
                list.appendChild(li);
            });

            overlay.style.display = "flex";

            setTimeout(() => {
                overlay.style.display = "none";
            }, 3000);

            hasGuessedCorrectly = false;  // Reset for new round
            resetPlayerColors();
            wordHint.textContent = "";
            document.getElementById("drawerText").textContent = "";

            guessBox.style.display = "block";
            toolRow.style.display = "none";
        });
</script>

</body>
</html>